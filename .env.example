# Copy to .env and adjust for local runs.

EV_MANHATTAN_HOST=127.0.0.1
EV_MANHATTAN_PORT=8000

# Reproducible sample scenario generation.
EV_MANHATTAN_SEED=7
EV_MANHATTAN_SAMPLE_CUSTOMERS=12
EV_MANHATTAN_SAMPLE_CHARGERS=4
EV_MANHATTAN_SAMPLE_DATE=2025-07-15
EV_MANHATTAN_SAMPLE_DIR=data/sample

# Optional runtime knobs.
RUN_PERF_TESTS=0
